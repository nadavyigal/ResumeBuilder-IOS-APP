// Copy this file to Secrets.swift and fill in the real values.
// Secrets.swift is listed in .gitignore — never commit it.
//
// Setup:
//   cp "ResumeBuilder IOS APP/Core/API/Secrets.swift.example" \
//      "ResumeBuilder IOS APP/Core/API/Secrets.swift"
//   Then replace REPLACE_ME with the real PostHog project API key.
//   The key is in the web project's NEXT_PUBLIC_POSTHOG_KEY env var.

enum Secrets {
    /// PostHog project API key (phc_…).
    /// Source: web project NEXT_PUBLIC_POSTHOG_KEY / PostHog Project ID 270848.
    static let posthogAPIKey = "REPLACE_ME"
}
